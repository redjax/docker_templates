## Default: (empty/unset)
#  Generate one with:
#    openssl rand -hex 32
VIKUNJA_JWT_SECRET=
## Default: http://localhost:3456
VIKUNJA_PUBLIC_URL=
## Default: true
VIKUNJA_ENABLE_REGISTRATION=
## Default: postgresql (included container)
VIKUNJA_DB_HOST=
## Default: ./vikunja/files
VIKUNJA_DATA_DIR=./vikunja/files
## Default: ./vikunja/cache
VIKUNJA_CACHE_DIR=./vikunja/cache
## Default: 3456
VIKUNJA_WEBUI_PORT=

## Default: vikunja
DB_USER=
## Default: vikunja
DB_PASSWORD=
## Default: vikunja
DB_DATABASE=
## Default: 16-alpine
DB_IMG_TAG=16-alpine
## Default: (named volume) db-data
DB_DATA_DIR=
