## See all configuration options at https://forgejo.org/docs/next/admin/config-cheat-sheet
#
#  To set an env var, use FORGEJO__config_section__VAR_NAME=value

# ---- Basic ----
FORGEJO____APP_NAME=Forgejo
FORGEJO____APP_SLOGAN=Beyond coding. We forge.

# ---- Server ----
FORGEJO__server__DOMAIN=localhost
FORGEJO__server__ROOT_URL=http://localhost:3000/
FORGEJO__server__HTTP_PORT=3000
FORGEJO__server__SSH_PORT=22
FORGEJO__server__SSH_DOMAIN=ssh.example.com
## Set this to false if forwarding SSH from the host
FORGEJO__server__START_SSH_SERVER=false
FORGEJO__server__PROTOCOL=http
FORGEJO__server__ENABLE_GZIP=true
FORGEJO__server__LANDING_PAGE=explore
FORGEJO__server__DISABLE_ROUTER_LOG=false

# ---- Database ----
FORGEJO__database__DB_TYPE=sqlite3
FORGEJO__database__HOST=
FORGEJO__database__NAME=/data/gitea.db
FORGEJO__database__USER=
FORGEJO__database__PASSWD=
FORGEJO__database__SSL_MODE=disable
FORGEJO__database__CHARSET=utf8mb4
FORGEJO__database__PATH=/data/gitea.db

# ---- Security ----
FORGEJO__security__INSTALL_LOCK=false
FORGEJO__security__SECRET_KEY=changeme
FORGEJO__security__INTERNAL_TOKEN=changeme

# ---- Repository ----
FORGEJO__repository__ROOT=/data/gitea-repositories
FORGEJO__repository__DEFAULT_BRANCH=main
FORGEJO__repository__ENABLE_PUSH_CREATE_USER=true
FORGEJO__repository__ENABLE_PUSH_CREATE_ORG=true
FORGEJO__repository__DISABLE_HTTP_GIT=false
FORGEJO__repository__FORCE_PRIVATE=false
FORGEJO__repository__DEFAULT_PUSH_CREATE_PRIVATE=false
FORGEJO__repository__ENABLE_PUSH_CREATE_USER=true
FORGEJO__repository__ENABLE_PUSH_CREATE_ORG=false
FORGEJO__repository__FILE_MAX_SIZE=50
FORGEJO__repository__MAX_FILES=5

# ---- Service ----
FORGEJO__service__REGISTER_EMAIL_CONFIRM=true
FORGEJO__service__ENABLE_NOTIFY_MAIL=false
FORGEJO__service__DISABLE_REGISTRATION=false
FORGEJO__service__REQUIRE_SIGNIN_VIEW=false
FORGEJO__service__DEFAULT_KEEP_EMAIL_PRIVATE=true
FORGEJO__service__DEFAULT_ALLOW_CREATE_ORGANIZATION=true

# ---- Mailer ----

FORGEJO__mailer__ENABLED=false
## Options: smtp, smtps, smtp+starttls, smtp+unix, sendmail, dummy
FORGEJO__mailer__PROTOCOL=smtp+starttls
## Mail server address, i.e. smtp.gmail.com
FORGEJO__mailer__SMTP_ADDR=
## Mail server port. If no protocol is set, it will be inferred from this value
#  Common options: 25 (insecure SMTP), 465 (SMTPS), 587 (STARTTLS)
FORGEJO__mailer__SMTP_PORT=587
## Use client certificate for TLS/SSL
FORGEJO__mailer__USE_CLIENT_CERT=false
FORGEJO__mailer__CLIENT_CERT_FILE=custom/mailer/cert.pem
FORGEJO__mailer__CLIENT_KEY_FILE=custom/mailer/key.pem
## Normally the user's email address
FORGEJO__mailer__USER=
## Account password or access token
FORGEJO__mailer__PASSWD=
## Path to a file containing the secret, i.e.:
#    file:/etc/forgejo/mailer_passwd
FORGEJO__mailer__PASSWD_URI=
## Mail from address, RFC 5322. This can be an email address, or
#  "Name" <email@example.com>
FORGEJO__mailer__FROM=
## Address set as the From address on the SMTP mail envelope. Set to <> to send an empty address.
FORGEJO__mailer__ENVELOPE_FROM=<>
## Prefix to be placed before email subject lines
FORGEJO__mailer__SUBJECT_PREFIX=
## Location of sendmail on the OS (command, or full path)
FORGEJO__mailer__SENDMAIL_PATH=sendmail
## Specify any extra sendmail arguments.
#  NOTE: you should be aware that email addresses can look like options; if your sendmail command takes
#  options, you must set the option terminator --.
FORGEJO__mailer__SENDMAIL_ARGS=
## Default: 5m. Timeout for sending mail through sendmail
FORGEJO__mailer__SENDMAIL_TIMEOUT=5m
## Most versions of sendmail prefer LF line endings rather than CRLF line endings.
#  Set this to false if your version of sendmail requires CRLF line endings.
FORGEJO__mailer__SENDMAIL_CONVERT_CRLF=true
## Send mails only in plain text, without an HTML alternative.
FORGEJO__mailer__SEND_AS_PLAIN_TEXT=false

# ---- Incoming email settings ----

## Enable handling of incoming emails.
FORGEJO__email_incoming__ENABLED=false
## The email address including the %{token} placeholder that will be replaced per user/action.
#  Example: incoming+%{token}@example.com. The placeholder must appear in the user part of the address (before the @).
FORGEJO__email_incoming__REPLY_TO_ADDRESS=
## IMAP server host.
FORGEJO__email_incoming__HOST=
## IMAP server port.
FORGEJO__email_incoming__PORT=
## Username of the receiving account.
FORGEJO__email_incoming__USERNAME=
## Password of the receiving account.
FORGEJO__email_incoming__PASSWORD=
## Instead of defining PASSWORD in the configuration, this option can be used to give Forgejo a path
#  to a file that contains the secret (example value: file:/etc/forgejo/email_incoming_password).
FORGEJO__email_incoming__PASSWORD_URI=
## Whether the IMAP server uses TLS.
FORGEJO__email_incoming__USE_TLS=false
## If set to true, completely ignores server certificate validation errors. This option is unsafe.
FORGEJO__email_incoming__SKIP_TLS_VERIFY=false
## The mailbox name where incoming mail will end up.
FORGEJO__email_incoming__MAILBOX=INBOX
## Whether handled messages should be deleted from the mailbox.
FORGEJO__email_incoming__DELETE_HANDLED_MESSAGE=true
## Maximum size of a message to handle. Bigger messages are ignored. Set to 0 to allow every size.
FORGEJO__email_incoming__MAXIMUM_MESSAGE_SIZE=10485760

# ---- Log ----
FORGEJO__log__MODE=console
FORGEJO__log__LEVEL=info
FORGEJO__log__ROOT_PATH=/data/log

# ---- Other Common Settings ----

## Theme options:
#  forgejo-auto, forgejo-light, forgejo-dark, gitea-auto,
#  gitea-light, gitea-dark, forgejo-auto-deuteranopia-protanopia,
#  forgejo-light-deuteranopia-protanopia, forgejo-dark-deuteranopia-protanopia,
#  forgejo-auto-tritanopia, forgejo-light-tritanopia, forgejo-dark-tritanopia
FORGEJO__ui__DEFAULT_THEME=forgejo-dark

FORGEJO__ui__DEFAULT_PAGING_NUM=100
## Number of repositories shown on one explore page
FORGEJO__ui__EXPLORE_PAGING_NUM=20
## Number of issues to show on one page
FORGEJO__ui__ISSUE_PAGING_NUM=20
## Number of members shown in organization members list
FORGEJO__ui__MEMBERS_PAGING_NUM=20
## Maximum number of commits shown in one activity feed
FORGEJO__ui__FEED_MAX_COMMIT_NUM=5
## Number of items displayed in the home feed
FORGEJO__ui__FEED_PAGING_NUM=20

## Maximum number of commits shown in the commit graph
FORGEJO__ui__GRAPH_MAX_COMMIT_NUM=100
## Number of lines of code shown for a code comment
FORGEJO__ui__CODE_COMMENT_LINES=4

##  Show user's email on the "explore users" page
SHOW_USER_EMAIL=false

FORGEJO__picture__DISABLE_GRAVATAR=false
FORGEJO__picture__ENABLE_FEDERATED_AVATAR=false

FORGEJO__oauth2__ENABLED=false

FORGEJO__session__PROVIDER=file
FORGEJO__session__COOKIE_SECURE=false

FORGEJO__metrics__ENABLED=false

# ---- Admin UI settings ----
FORGEJO__ui_admin__USER_PAGING_NUM=
FORGEJO__ui_admin__REPO_PAGING_NUM=
FORGEJO__ui_admin__NOTICE_PAGING_NUM=
FORGEJO__ui_admin__ORG_PAGING_NUM=

# ---- User UI settings ----
## Number of repos shown on one page
FORGEJO__ui_user_REPO_PAGING_NUM=15

# ---- UI CSV settings ----
## Max allowed file size in bytes to render CSV files as tables
#  Default: 524288 (512kb)
FORGEJO__ui_csv__MAX_FILE_SIZE=

# ---- UI Metadata settings ----
## Author meta tag for the homepage
FORGEJO__ui_meta__AUTHOR="Forgejo - Beyond coding. We forge."
## Description meta tag for the homepage
FORGEJO__ui_meta__DESCRIPTION="Forgejo is a self-hosted lightweight software forge. Easy to install and low maintenance, it just does the job."
## Keywords meta tag for the homepage
FORGEJO__ui_meta__KEYWORDS="git,forge,forgejo"

# ---- Storage (if using object storage) ----
# FORGEJO__storage__STORAGE_TYPE=local
# FORGEJO__storage__PATH=/data/gitea-attachments

# ---- LFS (Large File Storage) ----
FORGEJO__lfs__ENABLED=true
FORGEJO__lfs__CONTENT_PATH=/data/lfs

# ---- Actions (CI/CD) ----
FORGEJO__actions__ENABLED=true

# ---- Federation ----
FORGEJO__federation__ENABLED=false

# ---- Cron ----
FORGEJO__cron__ENABLED=true

# ---- SSH ----
FORGEJO__ssh__START_SSH_SERVER=false
FORGEJO__ssh__SSH_PORT=22
FORGEJO__ssh__DOMAIN=localhost

# ---- Attachment ----
FORGEJO__attachment__ENABLED=true
FORGEJO__attachment__PATH=/data/attachments

# ---- CAPTCHA ----
FORGEJO__captcha__ENABLED=false

# ---- OpenID ----
FORGEJO__openid__ENABLE_OPENID_SIGNIN=false
FORGEJO__openid__ENABLE_OPENID_SIGNUP=false

# ---- Webhook ----
FORGEJO__webhook__ALLOWED_HOST_LIST=*

# ---- API ----
FORGEJO__api__ENABLE_SWAGGER=true

# ---- Indexer ----
FORGEJO__indexer__ISSUE_INDEXER_TYPE=bleve
FORGEJO__indexer__REPO_INDEXER_ENABLED=true

# ---- CORS ----
FORGEJO__cors__ENABLED=false
FORGEJO__cors__ALLOW_CREDENTIALS=false
