## Default: enp2s0
WYL_IFACES=
## Default: Etc/UTC
TZ=America/New_York
## Default: (named volume) watchyourlan_data
WYL_DATA_DIR=./watchyourlan/data

## Default: influxdb
INFLUXDB_CONTAINER_NAME=influxdb-watchyourlan
## Default: 8086
INFLUXDB_HTTP_PORT=
## Default: setup
INFLUXDB_INIT_MODE=
## Default: admin
INFLUXDB_INIT_USERNAME=
## Default: influxAdmin
INFLUXDB_INIT_PASSWORD=
## Default: influxDefault
INFLUXDB_INIT_ORG=watchyourlan
## Default: influxDefaultBucket
INFLUXDB_INIT_BUCKET=watchyourlan
## Default: ./influxdb/data
INFLUXDB_DATA_DIR=
## Default: ./influxdb/config
INFLUXDB_CONFIG_DIR=

## Default: grafana
GRAFANA_CONTAINER_NAME=
## Default: 3000
GRAFANA_HTTP_PORT=
## Default: ./grafana/data
GRAFANA_DATA_DIR=grafana_data

