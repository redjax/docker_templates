## Pin Immich version
IMMICH_VERSION=release

TZ=America/New_York
LOG_LEVEL=simple

IMMICH_SERVER_PORT=2283

## Storage
UPLOAD_LOCATION=server-uploads
DB_DATA_LOCATION=db-data
MODEL_CACHE_DIR=model-cache

## Database
DB_HOSTNAME=database
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me_to_a_long_random_password
DB_DATABASE_NAME=immich

## Redis
REDIS_HOSTNAME=redis
REDIS_PORT=6379
REDIS_DBINDEX=0

## Caddy
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDYFILE=./Caddyfile
CADDY_DATA_DIR=caddy_data
CADDY_CONFIG_DIR=caddy_config
